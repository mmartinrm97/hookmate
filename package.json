{
  "name": "hookmate",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter @hookmate/api --filter @hookmate/dashboard dev",
    "dev:api": "pnpm --filter @hookmate/api dev",
    "dev:dashboard": "pnpm --filter @hookmate/dashboard dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:unit": "pnpm -r --if-present test:unit",
    "test:integration": "pnpm -r --if-present test:integration",
    "lint": "pnpm -r lint",
    "check": "pnpm lint && pnpm test && pnpm build",
    "ci:verify": "pnpm lint:lockfile && pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "audit": "pnpm audit --audit-level high",
    "audit:prod": "pnpm audit --prod --audit-level high",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "branch:check": "node scripts/validate-branch-name.mjs",
    "lint:lockfile": "node scripts/lint-pnpm-lockfile.mjs",
    "sonar": "node scripts/sonar.mjs",
    "infra:synth": "pnpm --filter @hookmate/infrastructure synth",
    "infra:deploy": "pnpm --filter @hookmate/infrastructure deploy",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "test:e2e:local": "bash scripts/test-e2e-local.sh",
    "test:e2e:local:cdk": "bash scripts/test-e2e-local.sh --cdk",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.5",
    "lockfile-lint": "^5.0.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@fastify/static": "^9.1.1",
      "uuid": ">=11.1.1"
    },
    "onlyBuiltDependencies": [
      "protobufjs"
    ]
  }
}
