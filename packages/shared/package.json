{
  "name": "@hookmate/shared",
  "version": "1.0.0",
  "description": "Shared contracts and metadata for HookMate",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
