# Registry
registry=https://registry.npmjs.org/

# Security
strict-ssl=true
audit-level=high

# Lockfile — always use frozen lockfile in CI, allow updates locally
lockfile=true

# pnpm workspace settings
shared-workspace-lockfile=true
link-workspace-packages=true
prefer-workspace-packages=true
save-workspace-protocol=rolling

# Peer dependencies
auto-install-peers=true
strict-peer-dependencies=false

# Hoist only tooling packages needed by editors/IDEs
# Everything else stays isolated per-package (pnpm default — better for security)
public-hoist-pattern[]=typescript
public-hoist-pattern[]=*types*

# Pin exact versions on install (no accidental patch/minor upgrades via semver)
save-exact=true

# Integrity / package-manager safety
verify-store-integrity=true
package-manager-strict=true

# Lifecycle scripts for pnpm are controlled via pnpm-workspace.yaml allowBuilds.
# ignore-scripts here would be redundant and could conflict with allowBuilds entries.
# For npm CLI users: set `ignore-scripts=true` in your global ~/.npmrc instead.
