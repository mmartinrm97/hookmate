# App
NODE_ENV=development
PORT=3000

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://hookmate:hookmate@localhost:5432/hookmate

# Redis — BullMQ (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# OpenAI
OPENAI_API_KEY=sk-replace-me

# AWS local — Floci emulator (port 4566)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# SQS queue URLs — created by Floci on startup
SQS_INGESTION_QUEUE_URL=http://localhost:4566/000000000000/hookmate-ingestion
SQS_DLQ_URL=http://localhost:4566/000000000000/hookmate-dlq

# SNS
SNS_ALARM_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:hookmate-alarms

# API key authentication (comma-separated list)
API_KEYS=local-dev-key

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d